# Local development env (used by `wrangler pages dev`).
# Copy to .dev.vars (gitignored) and fill in.
#
# Public (also set as a Pages env var so it ships to the client):
TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Secret (server-only):
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# Single-shared admin password — bcrypt hash, never the plaintext.
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=

# Random 32+ char string for signing the admin session cookie.
SESSION_SECRET=

# Resend (https://resend.com) — free tier 3k emails/mo.
RESEND_API_KEY=
EMAIL_FROM=bookings@balisbarber.com
EMAIL_TO_OWNER=owner@balisbarber.com

# Meta WhatsApp Cloud API — requires Meta Business verification.
# Leave blank to skip WhatsApp notifications; email still works.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_OWNER_NUMBER=6281337995251
