{
  "name": "balis-barber-booking",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler pages dev .svelte-kit/cloudflare",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "vite build && wrangler pages deploy .svelte-kit/cloudflare",
    "db:local:migrate": "wrangler d1 migrations apply balis_barber --local",
    "db:remote:migrate": "wrangler d1 migrations apply balis_barber --remote",
    "db:local:seed": "wrangler d1 execute balis_barber --local --file=migrations/0002_seed.sql",
    "db:remote:seed": "wrangler d1 execute balis_barber --remote --file=migrations/0002_seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251201.0",
    "@sveltejs/adapter-cloudflare": "^7.0.0",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  }
}
